# Gemini / LLM settings
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-2.5-flash
GEMINI_TEMPERATURE=0.1
GEMINI_TOP_P=0.8
GEMINI_TOP_K=10
GEMINI_MAX_OUTPUT_TOKENS=512

# App settings
APP_ENV=development
APP_PORT=8000
IS_PRODUCTION=false
USE_MOCK=true
APP_SECRET_KEY=dev-secret
LOG_LEVEL=INFO

# Google Cloud settings (only required if USE_MOCK=false)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./config/service-account.json
BQ_DATASET=peoples_priority
BQ_TABLE_SUBMISSIONS=submissions
BQ_TABLE_CLUSTERS=clusters
BQ_TABLE_SCORES=priority_scores

# Firebase settings (optional)
FIREBASE_DATABASE_URL=
FIREBASE_CREDENTIALS=./config/firebase-service-account.json

# Pub/Sub settings (optional)
PUBSUB_TOPIC_INGESTION=citizen-submissions
PUBSUB_TOPIC_PROCESSED=processed-submissions
PUBSUB_SUBSCRIPTION=pipeline-processor

# Twilio settings (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
TWILIO_SMS_NUMBER=

